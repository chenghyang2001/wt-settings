{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [
        {
            "id": "User.SplitPaneDupAlt",
            "command": { "action": "splitPane", "split": "auto", "splitMode": "duplicate" }
        }
    ],
    "centerOnLaunch": true,
    "copyFormatting": "none",
    "copyOnSelect": false,
    "defaultProfile": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
    "disabledProfileSources": ["Windows.Terminal.Azure"],
    "firstWindowPreference": "persistedWindowLayout",
    "keybindings": [
        {
            "id": "Terminal.ToggleSplitOrientation",
            "keys": "alt+r"
        },
        {
            "id": "Terminal.PrevTab",
            "keys": "alt+p"
        },
        {
            "id": "Terminal.CopyToClipboard",
            "keys": "ctrl+c"
        },
        {
            "id": "Terminal.PasteFromClipboard",
            "keys": "ctrl+v"
        },
        {
            "id": "Terminal.DuplicatePaneAuto",
            "keys": "alt+shift+d"
        },
        {
            "id": "User.SplitPaneDupAlt",
            "keys": "alt+s"
        },
        {
            "id": "Terminal.NextTab",
            "keys": "alt+n"
        },
        {
            "id": "Terminal.MoveFocusLeft",
            "keys": "alt+h"
        },
        {
            "id": "Terminal.MoveFocusDown",
            "keys": "alt+j"
        },
        {
            "id": "Terminal.MoveFocusUp",
            "keys": "alt+k"
        },
        {
            "id": "Terminal.MoveFocusRight",
            "keys": "alt+l"
        },
        {
            "command": { "action": "moveFocus", "direction": "nextInOrder" },
            "keys": "alt+f"
        },
        {
            "id": "Terminal.ResizePaneLeft",
            "keys": "alt+shift+left"
        },
        {
            "id": "Terminal.ResizePaneRight",
            "keys": "alt+shift+right"
        },
        {
            "id": "Terminal.ResizePaneUp",
            "keys": "alt+shift+up"
        },
        {
            "id": "Terminal.ResizePaneDown",
            "keys": "alt+shift+down"
        },
        {
            "id": "Terminal.TogglePaneZoom",
            "keys": "alt+z"
        },
        {
            "id": "Terminal.ClosePane",
            "keys": "alt+e"
        },
        {
            "id": "Terminal.MarkMode",
            "keys": "ctrl+shift+m"
        }
    ],
    "newTabMenu": [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles": {
        "defaults": {
            "bellStyle": [
                "window",
                "taskbar"
            ],
            "colorScheme": "One Half Dark",
            "cursorColor": "#FFCC00",
            "cursorShape": "filledBox",
            "font": {
                "face": "CaskaydiaCove Nerd Font",
                "size": 15
            },
            "historySize": 100000,
            "opacity": 75,
            "padding": "25, 25, 25, 25",
            "suppressApplicationTitle": false,
            "unfocusedAppearance": {
                "opacity": 70,
                "useAcrylic": true
            },
            "useAcrylic": true
        },
        "list": [
            {
                "commandline": "C:\\Program Files\\Git\\bin\\bash.exe --login -i",
                "guid": "{00000000-0000-0000-0000-000000000001}",
                "hidden": false,
                "icon": "C:\\Program Files\\Git\\mingw64\\share\\git\\git-for-windows.ico",
                "name": "Git Bash",
                "startingDirectory": "%USERPROFILE%"
            },
            {
                "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "hidden": false,
                "name": "Windows PowerShell",
                "startingDirectory": "%USERPROFILE%\\workspace"
            },
            {
                "commandline": "%SystemRoot%\\System32\\cmd.exe",
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "hidden": false,
                "name": "命令提示字元",
                "startingDirectory": "%USERPROFILE%\\workspace"
            },
            {
                "guid": "{2c4de342-38b7-51cf-b940-2309a097f518}",
